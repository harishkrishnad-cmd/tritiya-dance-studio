{
  "name": "tritiya-dance-studio",
  "version": "1.0.0",
  "description": "Tritiya Dance Studio Management App",
  "main": "server/index.js",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "start": "node server/index.js",
    "render:start": "node server/index.js",
    "build": "cd client && npm install && npm run build",
    "render:build": "cd client && npm install && npm run build",
    "dev": "concurrently \"nodemon server/index.js\" \"cd client && npm run dev\""
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "nodemailer": "^6.9.12",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0"
  }
}
